alias sudo='sudo '
alias ll='ls -hAlF'
ls --color=always &> /dev/null && alias ls='ls --color=always' || alias ls='ls -G'
alias grep='grep --color=auto'
alias mv='mv -i'
alias rm='rm -i'
alias cp='cp -i'
alias youtube-dl='yt-dlp'
alias gcp='git cherry-pick'
alias unrar='rar x'
alias json='python3 -m json.tool'
alias diff='diff --color=always'
alias git_reflog='git log --graph --oneline --reflog'
alias claude-ollama-27b='echo "tell app \"Terminal\" to set current settings of first window to settings set \"ClaudeLocalQwen27\"" | osascript && ollama launch claude --model qwen3.5:27b -- '
alias claude-ollama-9b='echo "tell app \"Terminal\" to set current settings of first window to settings set \"ClaudeLocalQwen9\"" | osascript && ollama launch claude --model qwen3.5:9b -- '
alias claude='echo "tell app \"Terminal\" to set current settings of first window to settings set \"Claude\"" | osascript && claude '
