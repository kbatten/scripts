+# - Otherwise (native non-Windows host): use native glslangValidator.
+if(CMAKE_HOST_WIN32)
     set(GLSLVALIDATOR glslangValidator.exe)
EOF
    echo "+elseif(WIN32 AND EXISTS \"${HOME}/.wine/drive_c/VulkanSDK/1.4.350.0/Bin/glslangValidator.exe\")
